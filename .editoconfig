# http://editorconfig.org
root = true

[*]
# 文字コード
charset = utf-8
# 改行コード (Windows/Mac/Linux間で統一)
end_of_line = lf
# ファイル末尾に空行を入れる
insert_final_newline = true
# 行末の不要なスペースを削除する
trim_trailing_whitespace = true
# インデントの種類 (space or tab)
indent_style = space
# インデントのサイズ
indent_size = 2

[*.{js,jsx,ts,tsx,vue,html,css,scss,json}]
# Webフロントエンド関連は一般的に2スペース
indent_size = 2

[*.py]
# PythonはPEP 8に従い4スペース
indent_style = space
indent_size = 4

[*.cs]
indent_style = space
indent_size = 4

[*.md]
# Markdownは行末スペースに意味がある場合があるため、自動削除を無効化
trim_trailing_whitespace = false

[Makefile]
# Makefileはタブが必須
indent_style = tab
